{
  "info": {
    "name": "Online Survey Service",
    "_postman_id": "online-survey-service-v1",
    "description": "Complete API test collection for Online Survey Service. \n\n**Setup:** \n1. Set `baseUrl` variable to `http://localhost:8080`\n2. Run 'Auth / Register Creator' first — access token auto-saves to collection variables.\n3. All authenticated requests use `{{accessToken}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "surveyId",     "value": "", "type": "string" },
    { "key": "questionId",   "value": "", "type": "string" },
    { "key": "responseId",   "value": "", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [

        {
          "name": "Register Creator",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "pm.test('Has accessToken', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.accessToken).to.be.a('string');",
                "  pm.collectionVariables.set('accessToken', body.accessToken);",
                "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                "});",
                "pm.test('Role is RESPONDENT', () => {",
                "  pm.expect(pm.response.json().user.role).to.equal('RESPONDENT');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@example.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"Survey Creator\"\n}"
            }
          }
        },

        {
          "name": "Register Admin",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('adminToken', pm.response.json().accessToken);",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"adminpass123\",\n  \"displayName\": \"Admin User\"\n}"
            }
          }
        },

        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('accessToken', body.accessToken);",
                "pm.collectionVariables.set('refreshToken', body.refreshToken);",
                "pm.test('Token type is Bearer', () => pm.expect(body.tokenType).to.equal('Bearer'));",
                "pm.test('expiresIn is positive', () => pm.expect(body.expiresIn).to.be.above(0));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },

        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('accessToken', body.accessToken);",
                "pm.collectionVariables.set('refreshToken', body.refreshToken);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },

        {
          "name": "Logout",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 204', () => pm.response.to.have.status(204));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },

        {
          "name": "Register — Validation Error (400)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                "pm.test('Has errors array', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.errors).to.be.an('array').that.is.not.empty;",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-valid-email\",\n  \"password\": \"short\",\n  \"displayName\": \"\"\n}"
            }
          }
        },

        {
          "name": "Login — Wrong Password (401)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 401', () => pm.response.to.have.status(401));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        }

      ]
    },

    {
      "name": "👤 Users",
      "item": [

        {
          "name": "Get My Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Has email', () => pm.expect(pm.response.json().email).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },

        {
          "name": "Update My Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Display name updated', () => {",
                "  pm.expect(pm.response.json().displayName).to.equal('Updated Name');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Updated Name\"\n}"
            }
          }
        },

        {
          "name": "Change Password",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 204', () => pm.response.to.have.status(204));"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword456\"\n}"
            }
          }
        },

        {
          "name": "Change Password — Wrong Current (400)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 401', () => pm.response.to.have.status(401));"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"wrongpassword\",\n  \"newPassword\": \"anotherpassword\"\n}"
            }
          }
        },

        {
          "name": "[ADMIN] List All Users",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Has content array', () => pm.expect(pm.response.json().content).to.be.an('array'));"
              ]
            }
          }],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }

      ]
    },

    {
      "name": "📋 Surveys",
      "item": [

        {
          "name": "Create Survey",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('surveyId', body.id);",
                "pm.test('Status is DRAFT', () => pm.expect(body.status).to.equal('DRAFT'));",
                "pm.test('Has slug', () => pm.expect(body.slug).to.be.a('string').and.not.empty);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Customer Satisfaction Survey\",\n  \"description\": \"Help us improve our service by answering a few questions.\",\n  \"anonymous\": false,\n  \"maxResponses\": 100\n}"
            }
          }
        },

        {
          "name": "Create Anonymous Survey",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "pm.test('Is anonymous', () => pm.expect(pm.response.json().anonymous).to.be.true);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Anonymous Feedback Form\",\n  \"description\": \"No login required.\",\n  \"anonymous\": true\n}"
            }
          }
        },

        {
          "name": "List Published Surveys (Public)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('Has pagination fields', () => {",
                "  pm.expect(body).to.have.all.keys('content','page','size','totalElements','totalPages','first','last');",
                "});"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys?page=0&size=20",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },

        {
          "name": "Search Published Surveys",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys?keyword=satisfaction&page=0&size=10",
              "query": [
                { "key": "keyword", "value": "satisfaction" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },

        {
          "name": "Get Survey by ID",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Has questions array', () => pm.expect(pm.response.json().questions).to.be.an('array'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}"
          }
        },

        {
          "name": "Get My Surveys",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys/my?page=0&size=10",
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },

        {
          "name": "Get My Surveys (Filter by DRAFT)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys/my?status=DRAFT&page=0&size=10",
              "query": [
                { "key": "status", "value": "DRAFT" },
                { "key": "page",   "value": "0" },
                { "key": "size",   "value": "10" }
              ]
            }
          }
        },

        {
          "name": "Update Survey",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Title updated', () => {",
                "  pm.expect(pm.response.json().title).to.equal('Updated: Customer Satisfaction Survey');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated: Customer Satisfaction Survey\",\n  \"description\": \"Updated description.\",\n  \"anonymous\": false,\n  \"maxResponses\": 200\n}"
            }
          }
        },

        {
          "name": "Publish Survey (DRAFT → PUBLISHED)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Status is PUBLISHED', () => {",
                "  pm.expect(pm.response.json().status).to.equal('PUBLISHED');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/status?status=PUBLISHED",
              "query": [{ "key": "status", "value": "PUBLISHED" }]
            }
          }
        },

        {
          "name": "Close Survey (PUBLISHED → CLOSED)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                "pm.test('Status is CLOSED', () => pm.expect(pm.response.json().status).to.equal('CLOSED'));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/status?status=CLOSED",
              "query": [{ "key": "status", "value": "CLOSED" }]
            }
          }
        },

        {
          "name": "Invalid Status Transition (422)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 422', () => pm.response.to.have.status(422));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/status?status=PUBLISHED",
              "query": [{ "key": "status", "value": "PUBLISHED" }]
            }
          }
        },

        {
          "name": "Duplicate Survey",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "pm.test('Title starts with Copy of', () => {",
                "  pm.expect(pm.response.json().title).to.include('Copy of');",
                "});",
                "pm.test('Status is DRAFT', () => pm.expect(pm.response.json().status).to.equal('DRAFT'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/duplicate"
          }
        },

        {
          "name": "Get Survey by Slug",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 200 or 404', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                "});"
              ]
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/surveys/slug/my-survey-slug-here"
          }
        },

        {
          "name": "Get Survey — Not Found (404)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                "pm.test('Problem Details format', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body.title).to.be.a('string');",
                "  pm.expect(body.status).to.equal(404);",
                "});"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/surveys/00000000-0000-0000-0000-000000000000"
          }
        },

        {
          "name": "Delete Survey",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 204', () => pm.response.to.have.status(204));"
              ]
            }
          }],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}"
          }
        }

      ]
    },

    {
      "name": "❓ Questions",
      "item": [

        {
          "name": "Add Text Question",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "const body = pm.response.json();",
                "pm.collectionVariables.set('questionId', body.id);",
                "pm.test('Type is TEXT', () => pm.expect(body.type).to.equal('TEXT'));",
                "pm.test('OrderIndex is 0', () => pm.expect(body.orderIndex).to.equal(0));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/questions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What is your full name?\",\n  \"helpText\": \"Please enter your first and last name.\",\n  \"type\": \"TEXT\",\n  \"required\": true\n}"
            }
          }
        },

