              "raw": "{\n  \"text\": \"How satisfied are you with our service?\",\n  \"type\": \"SINGLE_CHOICE\",\n  \"required\": true,\n  \"options\": [\n    { \"text\": \"Very Satisfied\" },\n    { \"text\": \"Satisfied\" },\n    { \"text\": \"Neutral\" },\n    { \"text\": \"Dissatisfied\" }\n  ]\n}"
            }
          }
        },

        {
          "name": "Add Multiple Choice Question",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "pm.test('Type is MULTIPLE_CHOICE', () => {",
                "  pm.expect(pm.response.json().type).to.equal('MULTIPLE_CHOICE');",
                "});"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/questions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Which features do you use? (Select all that apply)\",\n  \"type\": \"MULTIPLE_CHOICE\",\n  \"required\": false,\n  \"options\": [\n    { \"text\": \"Dashboard\" },\n    { \"text\": \"Reports\" },\n    { \"text\": \"Notifications\" },\n    { \"text\": \"API Access\" },\n    { \"text\": \"Mobile App\" }\n  ]\n}"
            }
          }
        },

        {
          "name": "Add Rating Question",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                "pm.test('Type is RATING', () => pm.expect(pm.response.json().type).to.equal('RATING'));",
                "pm.test('minValue is 1', () => pm.expect(pm.response.json().minValue).to.equal(1));",
                "pm.test('maxValue is 10', () => pm.expect(pm.response.json().maxValue).to.equal(10));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/surveys/{{surveyId}}/questions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"On a scale of 1-10, how likely are you to recommend us?\",\n  \"type\": \"RATING\",\n  \"required\": true,\n  \"minValue\": 1,\n  \"maxValue\": 10\n}"
